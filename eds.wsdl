            <element name="tg" type="xsd:unsignedByte" minOccurs="0" maxOccurs="unbounded"/><!-- eds__ObjectMetadata::tg -->
            <element name="md5" type="xsd:string" minOccurs="1" maxOccurs="1"/><!-- eds__ObjectMetadata::md5 -->
            <element name="hasPermission" type="xsd:boolean" minOccurs="1" maxOccurs="1"/><!-- eds__ObjectMetadata::hasPermission -->
