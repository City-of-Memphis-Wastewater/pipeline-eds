<portType name="edsPortType">
  <operation name="authenticate">
    <documentation>
      Checks user name and password.
    </documentation>
    <input message="tns:authenticateRequest"/>
    <output message="tns:authenticateResponse"/>
  </operation>
  <operation name="login">
    <documentation>
      Tries to create new session for client.
    </documentation>
    <input message="tns:loginRequest"/>
    <output message="tns:loginResponse"/>
  </operation>
  <operation name="logout">
    <documentation>
      Destroys clent session.
    </documentation>
    <input message="tns:logout"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="ping">
    <documentation>
      Revitalizes client session.
    </documentation>
    <input message="tns:ping"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="getTechnologicalGroups">
    <documentation>
      Returns a list of all technological groups (tg).
    </documentation>
    <input message="tns:getTechnologicalGroups"/>
    <output message="tns:GroupsResponse"/>
  </operation>
  <operation name="getSecurityGroups">
    <documentation>
      Returns a list of all security groups (sg).
    </documentation>
    <input message="tns:getSecurityGroups"/>
    <output message="tns:GroupsResponse"/>
  </operation>
  <operation name="getUserSecurityGroups">
    <documentation>
      Returns a list of security groups (sg) to which current user belongs.
    </documentation>
    <input message="tns:getUserSecurityGroups"/>
    <output message="tns:GroupsResponse"/>
  </operation>
  <operation name="getUsers">
    <documentation>
      Allows querying EDS92 for users matching selected criteria. It chooses all users matching the filter, sorts them using the requested order and returns a part of the result list defined by startIdx and maxCount. The order parameter should be a semicolon-separated list of user field names, in example: "description;name;id" or "created;-id". Adding "-" before a field name reverses the order. Full list of fields that may appear in the order parameter: id, name, description, locked, created, lastModified.
    </documentation>
    <input message="tns:getUsers"/>
    <output message="tns:getUsersResponse"/>
  </operation>
  <operation name="getEffectiveUserProfile">
    <documentation>
      Allows querying EDS92 user effective profile. Effective profile is composition of all profiles with user security groups access
    </documentation>
    <input message="tns:getEffectiveUserProfileRequest"/>
    <output message="tns:getEffectiveUserProfileResponse"/>
  </operation>
  <operation name="getServerTime">
    <documentation>
      Retrieves current server time.
    </documentation>
    <input message="tns:getServerTime"/>
    <output message="tns:getServerTimeResponse"/>
  </operation>
  <operation name="getServerStatus">
    <documentation>
      Returns information about current server status.
    </documentation>
    <input message="tns:getServerStatus"/>
    <output message="tns:getServerStatusResponse"/>
  </operation>
  <operation name="getServerConfig">
    <documentation>
      Retrieves EDS92 server basic configuration.
    </documentation>
    <input message="tns:getServerConfig"/>
    <output message="tns:getServerConfigResponse"/>
  </operation>
  <operation name="getObjectsMetadata">
    <documentation>
      Allows querying EDS92 for objects matching selected criteria. It chooses all objects matching the filter, sorts them using the requested order and returns a part of the resulting list defined by startIdx and maxCount. The order parameter should be a semicolon-separated list of ObjectMetadata fields names, for example: "sourceId" or "file;-name". Adding "-" before a field name reverses the order. Full list of fields that may appear in the order parameter: sourceId, file, name, lastModified, sourceName, hasPermission.
    </documentation>
    <input message="tns:getObjectsMetadata"/>
    <output message="tns:getObjectsMetadataResponse"/>
  </operation>
  <operation name="alterObject">
    <documentation>
      Source must be specified using either sourceId or sourceName; setting both sourceId and sourceName is an error. If some attribute in newAttributes is not set then it is not changed. Objects can be deleted via HTTP DEL request.
    </documentation>
    <input message="tns:alterObject"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="getObjectsSources">
    <documentation>
      Returns a list of all object sources if filter is not set or all object sources matching filter. Note: point sources and object sources might be completely different, even though in many cases they have similar names. Use getPointSources() to get a list of point sources. The order parameter should be a semicolon-separated list of ObjectSource field names, in example: "id" or "kind;-name". Adding "-" before a field name reverses the order. Full list of fields that may appear in the order parameter: id, name, desc, kind, host, prefix, suffix, hasPermission.
    </documentation>
    <input message="tns:getObjectsSources"/>
    <output message="tns:getObjectsSourcesResponse"/>
  </operation>
  <operation name="alterObjectSource">
    <documentation>
      Source must be specified using either sourceId or sourceName; setting both sourceId and sourceName is an error. If some attribute in newAttributes is not set then it is not changed.
    </documentation>
    <input message="tns:alterObjectSource"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="getPoints">
    <documentation>
      Allows querying EDS92 for points matching selected criteria. It chooses all points matching the filter, sorts them using the requested order and returns a part of the result list defined by startIdx and maxCount. The order parameter should be a semicolon-separated list of Point field names, in example: "zd;iess;sid" or "aux;-sid". Adding "-" before a field name reverses the order. Full list of fields that may appear in the order parameter: sid, value, dts, tss, at, atss, quality, iess, desc, rt, zd, idcs, ar, ap, aux, un, dp, artd, ard, tb, bb, hl, ll, dun, ddp, dartd, dard, dtb, dbb, dhl, dll, sd, rd.
    </documentation>
    <input message="tns:getPoints"/>
    <output message="tns:getPointsResponse"/>
  </operation>
  <operation name="getPointsWithCustomFilter">
    <documentation>Service definition of function eds__getPointsWithCustomFilter</documentation>
    <input message="tns:getPointsWithCustomFilter"/>
    <output message="tns:getPointsResponse"/>
  </operation>
  <operation name="getPointsSources">
    <documentation>
      Returns a list of all point sources. Note: point sources and object sources might be completely different, even though in many cases they have similar names. Use getObjectSources() to get a list of object sources.
    </documentation>
    <input message="tns:getPointsSources"/>
    <output message="tns:getPointsSourcesResponse"/>
  </operation>
  <operation name="getModifiedPoints">
    <documentation>
      Returns a list of points that have been modified after specified timestamp. However, if input dbSequence is different from database sequence number in EDS92, then all points from EDS92 are returned with disregard of the value of gptTimeStamp parameter. This method can be used to synchronize EDS92 points' database with the client's side. Only users belonging to admin group are authorized to use this method.
    </documentation>
    <input message="tns:getModifiedPoints"/>
    <output message="tns:getModifiedPointsResponse"/>
  </operation>
  <operation name="operatePoints">
    <documentation>
      Changes current points&amp;#39; values. PointNewValue::duration is ignored.
    </documentation>
    <input message="tns:operatePoints"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="publishPoints">
    <documentation>
      Set values will be automatically refreshed for PointNewValue::duration time after this call.
    </documentation>
    <input message="tns:publishPoints"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="unpublishPoints">
    <documentation>
      Turns off automatic refresh of points values. See publishPoints() method.
    </documentation>
    <input message="tns:unpublishPoints"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="getRequestStatus">
    <documentation>Service definition of function eds__getRequestStatus</documentation>
    <input message="tns:getRequestStatus"/>
    <output message="tns:getRequestStatusResponse"/>
  </operation>
  <operation name="dropRequest">
    <documentation>Service definition of function eds__dropRequest</documentation>
    <input message="tns:dropRequest"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="requestTrend">
    <documentation>
      Executes graphical trend. "pixelCount" parameter is just a suggestion to ArchSrv. When requesting trend for long time range 1 pixel can correspond to e.g. 1 day, that's why trend request may return up to 5 samples per pixel (value at the start of the range, maximum, minimum, value at the end, hole marker). See also getRequestStatus() and getTrend().
    </documentation>
    <input message="tns:requestTrendRequest"/>
    <output message="tns:requestTrendResponse"/>
  </operation>
  <operation name="getTrend">
    <documentation>
      Retrieves graphical trend request result. See also requestTrend() and getRequestStatus().
    </documentation>
    <input message="tns:getTrend"/>
    <output message="tns:getTrendResponse"/>
  </operation>
  <operation name="getTrendGroups">
    <documentation>
      Retrieves a list of trend groups migrated to the specified configuration version. If configuration version is unspecified, it defaults to the current version.
    </documentation>
    <input message="tns:getTrendGroups"/>
    <output message="tns:getTrendGroupsResponse"/>
  </operation>
  <operation name="requestTabular">
    <documentation>
      Tells the server to execute tabular trend. See also getRequestStatus() and getTabular().
    </documentation>
    <input message="tns:requestTabularRequest"/>
    <output message="tns:requestTabularResponse"/>
  </operation>
  <operation name="getTabular">
    <documentation>
      Retrieves tabular trend request result. See also requestTabular() and getRequestStatus().
    </documentation>
    <input message="tns:getTabular"/>
    <output message="tns:getTabularResponse"/>
  </operation>
  <operation name="getPointsWithShades">
    <documentation>Service definition of function eds__getPointsWithShades</documentation>
    <input message="tns:getPointsWithShades"/>
    <output message="tns:getPointsWithShadesResponse"/>
  </operation>
  <operation name="requestShadesRead">
    <documentation>
      Tells the server to read points shades as defined in request argument. The returned &lt;em&gt;requestId&lt;/em&gt; contains an identifier you can pass to getRequestStatus() to check current request state and later to getShades() to return requested shades.
    </documentation>
    <input message="tns:requestShadesReadRequest"/>
    <output message="tns:requestShadesReadResponse"/>
  </operation>
  <operation name="getShades">
    <documentation>
      Retrieves shades read request results. See also requestShadeRead() and getRequestStatus().
    </documentation>
    <input message="tns:getShades"/>
    <output message="tns:getShadesResponse"/>
  </operation>
  <operation name="requestShadesWrite">
    <documentation>
      Tells the server to overwrite points shades. See also getRequestStatus().
    </documentation>
    <input message="tns:requestShadesWriteRequest"/>
    <output message="tns:requestShadesWriteResponse"/>
  </operation>
  <operation name="requestShadesClear">
    <documentation>
      Tells the server to clear points shades for a specific time periods. See also getRequestStatus().
    </documentation>
    <input message="tns:requestShadesClearRequest"/>
    <output message="tns:requestShadesClearResponse"/>
  </operation>
  <operation name="requestShadesCopy">
    <documentation>
      Tells the server to copy shades between points. The points must be of the same type.
    </documentation>
    <input message="tns:requestShadesCopyRequest"/>
    <output message="tns:requestShadesCopyResponse"/>
  </operation>
  <operation name="requestEvents">
    <documentation>
      Requests historical event data. All returned Events will be ordered in reverse chronological order. See also getRequestStatus() and getEvents().
    </documentation>
    <input message="tns:requestEventsRequest"/>
    <output message="tns:requestEventsResponse"/>
  </operation>
  <operation name="getEvents">
    <documentation>
      Retrieves requestEvents() results.
    </documentation>
    <input message="tns:getEvents"/>
    <output message="tns:getEventsResponse"/>
  </operation>
  <operation name="addEvents">
    <documentation>
      Creates events of type EVENT-CUSTOM-MESSAGE.
    </documentation>
    <input message="tns:addEvents"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="getReportsConfigs">
    <documentation>
      Allows querying EDS92 for reports configs matching selected criteria.
    </documentation>
    <input message="tns:getReportsConfigs"/>
    <output message="tns:getReportsConfigsResponse"/>
  </operation>
  <operation name="createReportConfig">
    <documentation>
      Edits global report configuration.
    </documentation>
    <input message="tns:createReportConfig"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="alterReportConfig">
    <documentation>Service definition of function eds__alterReportConfig</documentation>
    <input message="tns:alterReportConfig"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="deleteReportConfig">
    <documentation>
      Deletes global report configuration.
    </documentation>
    <input message="tns:deleteReportConfig"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="requestGlobalReport">
    <documentation>
      Executes global report. See EDS92 Terminal documentation chapter 8 "Reporting" for details. See also requestCustomReport() and getRequestStatus().
    </documentation>
    <input message="tns:requestGlobalReportRequest"/>
    <output message="tns:requestGlobalReportResponse"/>
  </operation>
  <operation name="requestCustomReport">
    <documentation>
      Executes custom report. See EDS92 Terminal documentation chapter 8 "Reporting" for details. See also requestGlobalReport(), getRequestStatus() and getCustomReportResult().
    </documentation>
    <input message="tns:requestCustomReportRequest"/>
    <output message="tns:requestCustomReportResponse"/>
  </operation>
  <operation name="getCustomReport">
    <documentation>Service definition of function eds__getCustomReport</documentation>
    <input message="tns:getCustomReport"/>
    <output message="tns:getCustomReportResponse"/>
  </operation>
  <operation name="createGlobalReport">
    <documentation>Service definition of function eds__createGlobalReport</documentation>
    <input message="tns:createGlobalReport"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="requestScriptRun">
    <documentation>
      Starts predefined script. See also interactWithScript() and getRequestStatus().
    </documentation>
    <input message="tns:requestScriptRunRequest"/>
    <output message="tns:requestScriptRunResponse"/>
  </operation>
  <operation name="interactWithScript">
    <documentation>
      Interact with script started in requestScriptRun().
    </documentation>
    <input message="tns:interactWithScript"/>
    <output message="tns:interactWithScriptResponse"/>
  </operation>
  <operation name="openDiagram">
    <documentation>
      Opens diagram on EDS92 graphics server. Returns root URL in form http://GFX-HOST:GFX-PORT/UUID/. This URL is also an identifier of renderer session (URI) and should be used as url parameter in every diagram method. Current tag  will be avaiable under http://GFX-HOST:GFX-PORT/UUID/tag?_=CURRENT-TIME-STAMP. CURRENT-TIME-STAMP is needed to force suppressing cache on all communication levels (HTTP client, proxies, etc...). Meta data will be avaiable on http://GFX-HOST:GFX-PORT/UUID/meta.json?tag=TAG. Main window view will be avaiable under http://GFX-HOST:GFX-PORT/UUID/main.png?tag=TAG. List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:openDiagramRequest"/>
    <output message="tns:openDiagramResponse"/>
  </operation>
  <operation name="resizeDiagram">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:resizeDiagram"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="setDiagramViewport">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:setDiagramViewport"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="handleDiagramClick">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:handleDiagramClick"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="setDiagramEntryFieldValue">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:setDiagramEntryFieldValue"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="lockWindowDiagram">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:lockWindowDiagram"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="setActiveWindowDiagram">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:setActiveWindowDiagram"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="navigateDiagram">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:navigateDiagram"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="closeDiagram">
    <documentation>
      List of all diagram methods: openDiagram(), resizeDiagram(), setDiagramViewport(), handleDiagramClick(), setDiagramEntryFieldValue(), lockWindowDiagram(), setActiveWindowDiagram(), navigateDiagram(), closeDiagram().
    </documentation>
    <input message="tns:closeDiagram"/>
    <output message="tns:VoidResponse"/>
  </operation>
  <operation name="getGfxSrvFeatures">
