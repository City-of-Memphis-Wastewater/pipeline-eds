    <complexType name="ObjectFilter">
      <annotation>
        <documentation>
          Filter allows selecting objects using values of most of their fields. &lt;em&gt;SourceNameRe&lt;/em&gt;, &lt;em&gt;fileRe&lt;/em&gt; and &lt;em&gt;nameRe&lt;/em&gt; fields are Perl regular expressions. If more than one filter field is set, only objects matching all fields will match the whole filter.
        </documentation>
      </annotation>
          <sequence>
            <element name="fileRe" type="xsd:string" minOccurs="0" maxOccurs="1"/><!-- eds__ObjectFilter::fileRe -->
            <element name="nameRe" type="xsd:string" minOccurs="0" maxOccurs="1"/><!-- eds__ObjectFilter::nameRe -->
            <element name="sourceNameRe" type="xsd:string" minOccurs="0" maxOccurs="1"/><!-- eds__ObjectFilter::sourceNameRe -->
            <element name="sourceId" type="xsd:unsignedInt" minOccurs="0" maxOccurs="unbounded"/><!-- eds__ObjectFilter::sourceId -->
            <element name="modified" type="eds:TimePeriod" minOccurs="0" maxOccurs="1"/><!-- eds__ObjectFilter::modified -->
            <element name="sg" type="xsd:unsignedByte" minOccurs="0" maxOccurs="unbounded"/><!-- eds__ObjectFilter::sg -->
            <element name="tg" type="xsd:unsignedByte" minOccurs="0" maxOccurs="unbounded"/><!-- eds__ObjectFilter::tg -->
            <element name="md5" type="xsd:string" minOccurs="0" maxOccurs="unbounded"/><!-- eds__ObjectFilter::md5 -->
            <element name="withoutPermission" type="xsd:boolean" minOccurs="0" maxOccurs="1"/><!-- eds__ObjectFilter::withoutPermission -->
          </sequence>
    </complexType>
