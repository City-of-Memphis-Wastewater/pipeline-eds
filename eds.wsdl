    <complexType name="Timestamp">
      <annotation>
        <documentation>
          Represents a point in time, defined as the number of seconds elapsed since midnight proleptic Coordinated Universal Time (UTC) of January 1, 1970, not counting leap seconds.
        </documentation>
      </annotation>
          <sequence>
            <element name="second" type="xsd:long" minOccurs="1" maxOccurs="1"/><!-- eds__Timestamp::second -->
          </sequence>
    </complexType>
    <complexType name="TimeDuration">
